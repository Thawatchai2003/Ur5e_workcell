<?xml version="1.0" encoding="utf-8"?>
<robot name="box3">

  <!-- ================= BASE BODY ================= -->
  <link name="box3_base_link">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0"
               iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>

    <visual>
      <origin xyz="-0.29 -0.54 -0.12" rpy="0.0 0.0 1.5708"/>
      <geometry>
        <mesh filename="package://ur5e_workcell/meshes/meshes_Box3/base_link_BOX3.stl"
              scale="1 1 0.7"/>
      </geometry>
      <material name="box3_body">
        <color rgba="0.72 0.51 0.38 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <mesh filename="package://ur5e_workcell/meshes/meshes_Box3/base_link_BOX3.stl"
              scale="1 1 0.7"/>
      </geometry>
    </collision>

  </link>

  <!-- ================= EDGE / LINE ================= -->
  <link name="box3_edge_link">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>

    <visual>
      <origin xyz="0.1 -0.4 0.02" rpy="1.5708 0 1.5708"/>
      <geometry>
        <mesh filename="package://ur5e_workcell/meshes/meshes_Box3/Position_line3.stl"/>
      </geometry>
      <material name="box3_edge">
        <color rgba="0.8 0.1 0.1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <mesh filename="package://ur5e_workcell/meshes/meshes_Box3/Position_line3.stl"/>
      </geometry>
    </collision>

  </link>

  <!-- ================= FIXED JOINT ================= -->
  <joint name="box3_edge_fixed" type="fixed">
    <parent link="box3_base_link"/>
    <child link="box3_edge_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>