<?xml version="1.0" encoding="utf-8"?>
<robot name="box1">

  <!-- ================= BASE BOX (USE BOX3 MESH) ================= -->
  <link name="box1_base_link">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0"
               iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>

    <!-- ใช้ตัวกล่องหลักของ BOX3 -->
    <visual>
      <!-- สำคัญ: ใช้ origin แบบเดียวกับ Box3 -->
      <origin xyz="-0.29 -0.54 -0.12" rpy="0.0 0.0 1.5708"/>
      <geometry>
        <mesh filename="package://ur5e_workcell/meshes/meshes_Box3/base_link_BOX3.stl"
              scale="1 1 0.7"/>
      </geometry>
      <material name="box_body">
        <color rgba="0.72 0.55 0.38 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <mesh filename="package://ur5e_workcell/meshes/meshes_Box3/base_link_BOX3.stl"
              scale="1 1 0.7"/>
      </geometry>
    </collision>

  </link>


  <!-- ================= EDGE / LINE (USE BOX3 EDGE) ================= -->
  <link name="box1_edge_link">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>

    <!-- ใช้ edge ของ BOX3 -->
    <visual>
      <origin xyz="0.1 -0.4 0.025" rpy="1.5708 0 1.5708"/>
      <geometry>
        <mesh filename="package://ur5e_workcell/meshes/meshes_Box3/Position_line3.stl"/>
      </geometry>
      <material name="box_edge">
        <color rgba="0.8 0.1 0.1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <mesh filename="package://ur5e_workcell/meshes/meshes_Box3/Position_line3.stl"/>
      </geometry>
    </collision>

  </link>


  <!-- ================= FIXED JOINT ================= -->
  <joint name="box1_edge_fixed" type="fixed">
    <parent link="box1_base_link"/>
    <child link="box1_edge_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>